def f(bools) {
    indices = Indices(bools);
    diagonal_mat = Select(indices, indices, <=);
    plus_one = (Indices + 1)(bools);
    indicated = Indicator(bools);
    a = plus_one * Aggregate(diagonal_matrix, plus_one);
    return a;
}

input = "(())()";

num_open = (Tokens == "(")(input);
num_closed = (Tokens == ")")(input);
opens = f(num_open);
closed = f(num_closed);
balance = opens - closed;

for e in closed {
    Print(e);
}
